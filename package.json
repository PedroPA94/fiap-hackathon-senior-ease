{
  "name": "fiap-hackathon-senior-ease",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:package-exports": "pnpm --filter @senior-ease/package-exports-smoke test:package-exports",
    "start:web": "pnpm --filter @senior-ease/web start",
    "start:mobile": "pnpm --filter @senior-ease/mobile start",
    "start:mobile:android": "pnpm --filter @senior-ease/mobile android",
    "start:mobile:ios": "pnpm --filter @senior-ease/mobile ios"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "latest"
  }
}

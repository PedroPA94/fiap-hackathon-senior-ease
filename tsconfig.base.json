{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@senior-ease/core": ["./packages/core/src/index.ts"],
      "@senior-ease/tokens": ["./packages/tokens/src/index.ts"]
    }
  }
}
